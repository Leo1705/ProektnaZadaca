generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  role          String    // "student" | "teacher" | "admin"
  year          Int?      // 1-4 for students (година)
  profileImage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Student relations
  studentSubjects    StudentSubject[]
  homeworkSubmissions HomeworkSubmission[]

  // Teacher relations
  taughtSubjects     Subject[]         @relation("SubjectTeacher")
  teacherAssignments TeacherAssignment[]
  feedback           Feedback[]

  // Admin creates teachers
  createdTeachers    User[]            @relation("AdminCreatedTeachers")
  createdById        String?
  createdBy          User?             @relation("AdminCreatedTeachers", fields: [createdById], references: [id])
}

model Subject {
  id          String   @id @default(cuid())
  name        String
  description String?
  teacherId   String
  teacher     User     @relation("SubjectTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  year        Int      // 1-4 - which year this subject is for
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules     Module[]
  homework    Homework[]
  students    StudentSubject[]
  resources   SubjectResource[]
}

model StudentSubject {
  id        String   @id @default(cuid())
  studentId String
  subjectId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([studentId, subjectId])
}

model TeacherAssignment {
  id        String   @id @default(cuid())
  teacherId String
  subjectId String
  year      Int      // class year 1-4
  teacher   User     @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([teacherId, subjectId, year])
}

model SubjectResource {
  id        String   @id @default(cuid())
  subjectId String
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title     String
  type      String   // "file" | "link"
  url       String
  createdAt DateTime @default(now())
}

model Module {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  resources Resource[]
}

model Resource {
  id        String   @id @default(cuid())
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title     String
  type      String   // "file" | "link" | "document"
  url       String   // file path or URL
  createdAt DateTime @default(now())
}

model Homework {
  id          String   @id @default(cuid())
  subjectId   String
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  dueDate     DateTime?
  maxPoints   Int?     // максимални поени (опционално)
  published   Boolean  @default(false)  // видлива за студенти само кога true
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions HomeworkSubmission[]
  resources   HomeworkResource[]
}

model HomeworkResource {
  id         String   @id @default(cuid())
  homeworkId String
  homework   Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  title      String
  type       String   // "file" | "link"
  url        String
  createdAt  DateTime @default(now())
}

model HomeworkSubmission {
  id         String    @id @default(cuid())
  homeworkId String
  studentId  String
  fileUrl    String?
  comment    String?
  submittedAt DateTime @default(now())
  homework   Homework  @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  student    User      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feedback   Feedback[]
}

model Feedback {
  id             String    @id @default(cuid())
  submissionId   String
  teacherId      String
  comment        String
  createdAt      DateTime  @default(now())
  submission     HomeworkSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  teacher        User      @relation(fields: [teacherId], references: [id], onDelete: Cascade)
}

